{
  "name": "keihi-gen",
  "version": "1.0.1",
  "description": "経費ぽん",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "dist": "npm run build"
  },
  "keywords": [
    "経費",
    "画像処理",
    "receipt"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "electron": "~41.5.0",
    "electron-builder": "^26.8.1",
    "heic2any": "^0.0.4"
  },
  "build": {
    "appId": "com.keihigen.app",
    "productName": "KeiHiPon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "style.css",
      "script.js",
      "main.js",
      "preload.js",
      "package.json",
      "lib/heic2any.min.js"
    ],
    "afterPack": "scripts/afterPack.js",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": false,
      "extendInfo": {
        "CFBundleDisplayName": "経費ぽん"
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
